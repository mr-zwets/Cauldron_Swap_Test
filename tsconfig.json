{
  "compilerOptions": {
    "target": "es2024",
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "strict": true,
    "noUncheckedSideEffectImports": true,
    "libReplacement": false,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "rootDir": "./src",
    "outDir": "./dist",
    "declaration": true,
    "types": []
  },
  "include": ["./src"]
}
